rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /poems/{poemId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner() {
        return isSignedIn() && resource.data.userId == request.auth.uid;
      }

      function isLegacyPoem() {
        return !("userId" in resource.data) || resource.data.userId == null || resource.data.userId == "";
      }

      function claimMatchesEmail() {
        return resource.data.userEmail is string
          && resource.data.userEmail != ""
          && request.auth.token.email is string
          && request.auth.token.email != ""
          && resource.data.userEmail == request.auth.token.email;
      }

      function claimKeepsCoreContent() {
        return request.resource.data.title == resource.data.title
          && request.resource.data.content == resource.data.content
          && request.resource.data.author == resource.data.author
          && request.resource.data.createdAt == resource.data.createdAt;
      }

      function isValidLegacyClaim() {
        return isSignedIn()
          && isLegacyPoem()
          && claimMatchesEmail()
          && claimKeepsCoreContent()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.userEmail == request.auth.token.email;
      }

      allow read: if true;
      allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner() || isValidLegacyClaim();
      allow delete: if isOwner();
    }
  }
}
